#!/bin/sh
set -e

cd /app/api

mkdir -p /data tmp/pids

export DATABASE_PATH="${DATABASE_PATH:-/data/production.sqlite3}"
export DATABASE_CACHE_PATH="${DATABASE_CACHE_PATH:-/data/production_cache.sqlite3}"
export DATABASE_QUEUE_PATH="${DATABASE_QUEUE_PATH:-/data/production_queue.sqlite3}"
export DATABASE_CABLE_PATH="${DATABASE_CABLE_PATH:-/data/production_cable.sqlite3}"

if [ "${RAILS_ENV:-production}" = "production" ] && [ -z "${RAILS_MASTER_KEY:-}" ] && [ ! -f config/master.key ]; then
  echo "ERROR: RAILS_MASTER_KEY is required in production."
  echo "Set it on Fly with: fly secrets set RAILS_MASTER_KEY=\"\$(cat api/config/master.key)\" -a kadince-task-list-assignment"
  exit 1
fi

if [ "$1" = "bin/rails" ] && { [ "$2" = "server" ] || [ "$2" = "s" ]; }; then
  if [ "${SEED_ON_BOOT:-false}" = "true" ]; then
    echo "Seeding database..."
    bin/rails db:seed
  fi

  rm -f tmp/pids/server.pid
fi

echo "Starting application..."
exec "$@"
