# Copy this file to `.env` and fill in your values. Never commit `.env`.
#
#   cp .env.example .env

# --- Local development (Docker Compose) ---

# GraphQL URL for the React app. In Docker dev, Vite proxies `/graphql` to the API.
VITE_GRAPHQL_URL=/graphql

# Allowed browser origins for the Rails API (comma-separated).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- AI (Groq) — https://console.groq.com ---

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
AI_PROVIDER=groq

# --- Local development (without Docker) ---

# Uncomment if running the API and client directly on your machine:
# VITE_GRAPHQL_URL=http://localhost:3000/graphql

# --- Production (set on the host, not in this file) ---

# Fly.io (`fly secrets set`):
#   RAILS_MASTER_KEY=copy_from_api/config/master.key
#   GROQ_API_KEY=your_groq_api_key_here
#   CORS_ORIGINS=https://your-app.vercel.app

# Vercel (Project → Settings → Environment Variables):
#   VITE_GRAPHQL_URL=https://your-api.fly.dev/graphql
