# SQLite database files live in api/storage/ (created automatically on first boot)

# Frontend GraphQL endpoint (local dev uses Vite proxy; production uses your Fly.io URL)
VITE_GRAPHQL_URL=/graphql

# AI (Groq) — get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
AI_PROVIDER=groq

# CORS — comma-separated frontend origins allowed to call the API
# Local dev (default): http://localhost:5173,http://127.0.0.1:5173
# Production example: https://your-app.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Fly.io only (set via `fly secrets set`)
# RAILS_MASTER_KEY=copy_from_api/config/master.key
# CORS_ORIGINS=https://your-app.vercel.app

# Vercel only (Project → Settings → Environment Variables)
# VITE_GRAPHQL_URL=https://kadince-task-list-api.fly.dev/graphql
